{
    "name": "Travel Packer Dev Environment",
    "image": "mcr.microsoft.com/devcontainers/python:3.11",
    "forwardPorts": [5000],
    "portsAttributes": {
        "5000": {
            "label": "Aplicación Web (Flask)",
            "onAutoForward": "notify"
        }
    },
    "postCreateCommand": "pip install -r requirements.txt",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance"
            ]
        }
    }
}
